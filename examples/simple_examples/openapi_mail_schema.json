{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exonware.com/schemas/openapi-mail-schema.json",
  "title": "OpenAPI 3.0 with Mail Server Settings",
  "description": "JSON Schema for OpenAPI 3.0 documents with extended settings (logging, rate limits, features).",
  "type": "object",
  "required": ["openapi", "info", "paths"],
  "properties": {
    "openapi": { "type": "string", "pattern": "^3\\.0\\.[0-9]+$", "description": "OpenAPI version" },
    "info": {
      "type": "object",
      "required": ["title", "version"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "termsOfService": { "type": "string", "format": "uri" },
        "contact": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string", "format": "uri" },
            "email": { "type": "string", "format": "email" }
          }
        },
        "license": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string", "format": "uri" }
          }
        },
        "version": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "format": "uri-template" },
          "description": { "type": "string" },
          "variables": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "default": { "type": "string" },
                "enum": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/PathItem"
      },
      "minProperties": 1
    },
    "components": {
      "type": "object",
      "properties": {
        "schemas": { "type": "object", "additionalProperties": { "$ref": "#/$defs/SchemaObject" } },
        "parameters": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Parameter" } },
        "responses": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Response" } },
        "requestBodies": { "type": "object", "additionalProperties": { "$ref": "#/$defs/RequestBody" } },
        "securitySchemes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["apiKey", "http", "oauth2", "openIdConnect"] },
              "description": { "type": "string" },
              "name": { "type": "string" },
              "in": { "type": "string", "enum": ["query", "header", "cookie"] },
              "scheme": { "type": "string" },
              "bearerFormat": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "security": { "type": "array", "items": { "type": "object" } },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "externalDocs": {
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "description": { "type": "string" }
      }
    },
    "x-settings": {
      "type": "object",
      "description": "Application settings extension",
      "properties": {
        "logging": {
          "type": "object",
          "properties": {
            "level": { "type": "string", "enum": ["debug", "info", "warning", "error"] },
            "format": { "type": "string", "enum": ["json", "text"] },
            "output": { "type": "string", "enum": ["stdout", "stderr", "file"] }
          }
        },
        "rateLimit": {
          "type": "object",
          "properties": {
            "requestsPerMinute": { "type": "integer", "minimum": 1, "maximum": 10000 },
            "burst": { "type": "integer", "minimum": 1 }
          }
        },
        "features": {
          "type": "object",
          "properties": {
            "attachments": { "type": "boolean" },
            "threading": { "type": "boolean" },
            "search": { "type": "boolean" },
            "imap": { "type": "boolean" },
            "smtp": { "type": "boolean" }
          }
        },
        "storage": {
          "type": "object",
          "properties": {
            "backend": { "type": "string", "enum": ["local", "s3", "azure"] },
            "maxMessageSize": { "type": "integer", "minimum": 1024 },
            "retentionDays": { "type": "integer", "minimum": 1 }
          }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "PathItem": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "get": { "$ref": "#/$defs/Operation" },
        "put": { "$ref": "#/$defs/Operation" },
        "post": { "$ref": "#/$defs/Operation" },
        "delete": { "$ref": "#/$defs/Operation" },
        "patch": { "$ref": "#/$defs/Operation" },
        "parameters": { "type": "array", "items": { "$ref": "#/$defs/Parameter" } }
      },
      "additionalProperties": true
    },
    "Operation": {
      "type": "object",
      "properties": {
        "tags": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "operationId": { "type": "string" },
        "parameters": { "type": "array", "items": { "$ref": "#/$defs/Parameter" } },
        "requestBody": { "$ref": "#/$defs/RequestBody" },
        "responses": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/Response" },
          "minProperties": 1
        },
        "security": { "type": "array" },
        "deprecated": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "Parameter": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "in": { "type": "string", "enum": ["query", "header", "path", "cookie"] },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "schema": { "$ref": "#/$defs/SchemaObject" }
      },
      "additionalProperties": true
    },
    "RequestBody": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "content": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "schema": { "$ref": "#/$defs/SchemaObject" },
              "examples": { "type": "object" }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "Response": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "content": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "schema": { "$ref": "#/$defs/SchemaObject" }
            }
          }
        },
        "headers": { "type": "object" }
      },
      "additionalProperties": true
    },
    "SchemaObject": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["string", "number", "integer", "boolean", "array", "object"] },
        "format": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "default": {},
        "enum": { "type": "array" },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "minLength": { "type": "integer" },
        "maxLength": { "type": "integer" },
        "pattern": { "type": "string" },
        "items": { "$ref": "#/$defs/SchemaObject" },
        "properties": { "type": "object", "additionalProperties": { "$ref": "#/$defs/SchemaObject" } },
        "required": { "type": "array", "items": { "type": "string" } },
        "$ref": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
